{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "bundle": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "watch": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "zip": {
      "dependsOn": ["build"]
    }
  }
}
