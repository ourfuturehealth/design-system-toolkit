{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", "site/dist/**"],
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test:jest": {
      "outputs": []
    },
    "test:vitest": {
      "outputs": []
    },
    "test:vitest:watch": {
      "cache": false,
      "persistent": true
    },
    "test:all": {
      "dependsOn": ["test:jest", "test:vitest"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    }
  }
}
