{% set pageTitle = "Button" %}
{% set pageSection = "Design system" %}
{% set subSection = "Components" %}
{% set pageDescription = "Use the Button component to help users carry out an action on a page, such as starting an application or saving their progress." %}
{% set theme = "Form elements" %}
{% set dateUpdated = "March 2026" %}
{% set backlog_issue_id = "7" %}

{% extends "app-layout.njk" %}

{% block breadcrumb %}
  {% include "../_breadcrumb.njk" %}
{% endblock %}

{% block bodyContent %}
  <p>Use the contained button for the main action on a page, and choose outlined, ghost or text variants for lower-emphasis actions.</p>
  <p>Use <code>href</code> when the control takes a user to another page or location. Keep it as a real button when it submits a form or triggers an action on the current page, and set <code>type</code> explicitly for form buttons so the behaviour is clear.</p>
  <p>Use the inverted variants only on dark backgrounds.</p>

  <p>The Button component has 6 variants.</p>
  <ul>
    <li><a href="#contained-button">Contained</a></li>
    <li><a href="#outlined-button">Outlined</a></li>
    <li><a href="#ghost-button">Ghost</a></li>
    <li><a href="#ghost-inverted-button">Ghost inverted</a></li>
    <li><a href="#text-button">Text</a></li>
    <li><a href="#text-inverted-button">Text inverted</a></li>
  </ul>

  <h2 id="contained-button">Contained button</h2>
  {{ designExample({
    group: "components",
    item: "buttons",
    itemTitle: "button",
    type: "default"
  }) }}

  <h2 id="outlined-button">Outlined button</h2>
  {{ designExample({
    group: "components",
    item: "buttons",
    itemTitle: "button",
    type: "outlined"
  }) }}

  <h2 id="ghost-button">Ghost button</h2>
  {{ designExample({
    group: "components",
    item: "buttons",
    itemTitle: "button",
    type: "ghost"
  }) }}

  <h2 id="ghost-inverted-button">Ghost inverted button</h2>
  {{ designExample({
    group: "components",
    item: "buttons",
    itemTitle: "button",
    type: "ghost-inverted",
    bgColour: "medium-blue"
  }) }}

  <h2 id="text-button">Text button</h2>
  {{ designExample({
    group: "components",
    item: "buttons",
    itemTitle: "button",
    type: "text"
  }) }}

  <h2 id="text-inverted-button">Text inverted button</h2>
  {{ designExample({
    group: "components",
    item: "buttons",
    itemTitle: "button",
    type: "text-inverted"
  }) }}
{% endblock %}
