{% set pageTitle = "Do and Don't lists" %}
{% set pageSection = "Design system" %}
{% set subSection = "Components" %}
{% set pageDescription = "Do and Don't lists are now documented as Card / Do & Don’t. This page remains for migration guidance." %}
{% set theme = "Content presentation" %}
{% set dateUpdated = "March 2026" %}
{% set backlog_issue_id = "DSE-324" %}

{% extends "app-layout.njk" %}

{% block breadcrumb %}
  {% include "../_breadcrumb.njk" %}
{% endblock %}

{% block bodyContent %}

  <p><strong>Do and Don't lists have moved.</strong> Use <a href="/design-system/components/card-do-dont">Card / Do &amp; Don’t</a> for the current design-system guidance and API.</p>

  {{ designExample({
    group: "components",
    item: "card-do-dont",
    type: "default"
  }) }}

  <h2>Migration guidance</h2>
  <p>The legacy <code>list()</code> macro is still available for compatibility, but it now renders the Card / Do &amp; Don’t component.</p>
  <p>For new work, use <code>cardDoDont()</code> with <code>type: 'do'</code> or <code>type: 'dont'</code>.</p>

  <h2>What changed</h2>
  <ul>
    <li>The component is now part of the Card family under Content presentation</li>
    <li>The header background uses the brand background and the icons are 32px</li>
    <li>Padding and spacing now match the current Figma design</li>
  </ul>

  <h2>Example migration</h2>
  <p>Before:</p>
  <pre><code>{% raw %}{% from 'components/do-dont-list/macro.njk' import list %}

{{ list({
  title: 'Do',
  type: 'tick',
  items: [
    { item: 'cover blisters that are likely to burst' }
  ]
}) }}{% endraw %}</code></pre>

  <p>After:</p>
  <pre><code>{% raw %}{% from 'components/card-do-dont/macro.njk' import cardDoDont %}

{{ cardDoDont({
  type: 'do',
  items: [
    { item: 'cover blisters that are likely to burst' }
  ]
}) }}{% endraw %}</code></pre>

{% endblock %}
