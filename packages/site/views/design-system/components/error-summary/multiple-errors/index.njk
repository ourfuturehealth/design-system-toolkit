{% from 'error-summary/macro.njk' import errorSummary %}
{% from 'input/macro.njk' import input %}

{{ errorSummary({
  "titleText": "There is a problem",
  "idPrefix": "multiple-errors",
  "errorList": [
    {
      "text": "Enter your first name",
      "href": "#first-name"
    },
    {
      "text": "Enter your last name",
      "href": "#last-name"
    }
  ]
}) }}

<h1 class="ofh-heading-lg">Your details</h1>

{{ input({
  "label": {
    "text": "First name"
  },
  "id": "first-name",
  "name": "first-name",
  "errorMessage": {
    "text": "Enter your first name"
  }
}) }}

