{% set pageTitle = "Warning callout" %}
{% set pageSection = "Design system" %}
{% set subSection = "Components" %}
{% set pageDescription = "Warning callout is now documented as Card / Callout. This page remains for migration guidance." %}
{% set theme = "Content presentation" %}
{% set dateUpdated = "March 2026" %}
{% set backlog_issue_id = "DSE-324" %}

{% extends "app-layout.njk" %}

{% block breadcrumb %}
  {% include "../_breadcrumb.njk" %}
{% endblock %}

{% block bodyContent %}

  <p><strong>Warning callout has moved.</strong> Use <a href="/design-system/components/card-callout">Card / Callout</a> for the current design-system guidance and API.</p>

  {{ designExample({
    group: "components",
    item: "card-callout",
    type: "default"
  }) }}

  <h2>Migration guidance</h2>
  <p>The legacy <code>warningCallout()</code> macro is still available for compatibility, but it now renders the Card / Callout warning variant.</p>
  <p>For new work, use <code>cardCallout()</code> with <code>variant: 'warning'</code>.</p>

  <h2>What changed</h2>
  <ul>
    <li>Warning callout is now part of the Card family under Content presentation</li>
    <li>The updated component supports <code>info</code>, <code>warning</code>, <code>success</code> and <code>error</code> variants</li>
    <li>Spacing, fill and border colours now match the current Figma design</li>
  </ul>

  <h2>Example migration</h2>
  <p>Before:</p>
  <pre><code>{% raw %}{% from 'components/warning-callout/macro.njk' import warningCallout %}

{{ warningCallout({
  heading: 'Important',
  HTML: '&lt;p&gt;Check the details in this section before you continue.&lt;/p&gt;'
}) }}{% endraw %}</code></pre>

  <p>After:</p>
  <pre><code>{% raw %}{% from 'components/card-callout/macro.njk' import cardCallout %}

{{ cardCallout({
  heading: 'Warning',
  variant: 'warning',
  html: '&lt;p&gt;Check the details in this section before you continue.&lt;/p&gt;'
}) }}{% endraw %}</code></pre>

{% endblock %}
