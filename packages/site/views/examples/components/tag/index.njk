{% set html_style = 'background-color: #f0f4f5;' %}
{% set pageTitle = 'Tag' %}
{% from 'tag/macro.njk' import tag %}
{% extends 'standalone-example-layout.njk' %}

{% block body %}

  <div class="ofh-width-container">
    <main class="ofh-main-wrapper" id="maincontent">

      <div class="ofh-grid-row">
        <div class="ofh-grid-column-two-thirds">

          <table class="ofh-table">
            <thead class="ofh-table__head">
              <tr class="ofh-table__row">
                <th class="ofh-table__header" scope="col">Class name</th>
                <th class="ofh-table__header" scope="col" style="width: 120px">Tag</th>
              </tr>
            </thead>
            <tbody class="ofh-table__body">
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag</code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "Default"
                  })}}
                </td>
              </tr>
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag--neutral </code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "Inactive",
                    classes: "ofh-tag--neutral"
                  })}}
                </td>
              </tr>
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag--brand </code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "Beta",
                    classes: "ofh-tag--brand"
                  })}}
                </td>
              </tr>
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag--blue </code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "Ready",
                    classes: "ofh-tag--blue"
                  })}}
                </td>
              </tr>
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag--green </code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "In progress",
                    classes: "ofh-tag--green"
                  })}}
                </td>
              </tr>
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag--yellow </code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "Delayed",
                    classes: "ofh-tag--yellow"
                  })}}
                </td>
              </tr>
              <tr class="ofh-table__row">
                <td class="ofh-table__cell">
                  <code> ofh-tag--red </code>
                </td>
                <td class="ofh-table__cell">
                  {{ tag({
                    text: "Urgent",
                    classes: "ofh-tag--red"
                  })}}
                </td>
              </tr>
            </tbody>
          </table>

        </div>
      </div>

    </main>
  </div>

{% endblock %}
