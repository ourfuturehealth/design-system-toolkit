{% set html_style = 'background-color: #f0f4f5;' %}
{% set pageTitle = 'Basic card with icon' %}
{% from 'card/macro.njk' import card %}
{% extends 'standalone-example-layout.njk' %}

{% block body %}

  <div class="ofh-width-container">
    <main class="ofh-main-wrapper" id="maincontent">
      <div class="ofh-grid-row">
        <div class="ofh-grid-column-two-thirds">
          {{ card({
            "heading": "Profile complete",
            "headingLevel": "3",
            "description": "You’ve completed all the required profile details.",
            "icon": {
              "name": "Done",
              "size": 32,
              "color": "#00725F"
            }
          }) }}
        </div>
      </div>
    </main>
  </div>

{% endblock %}
