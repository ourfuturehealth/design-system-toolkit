{% from 'header/macro.njk' import header %}

{% macro siteHeader(currentSection='') %}
  {{ header({
    "theme": "light",
    "brand": {
      "href": "/",
      "ariaLabel": "Our Future Health design system home"
    },
    "navigation": [
      {
        "href": "/get-started",
        "label": "Get started",
        "current": currentSection == "Get started"
      },
      {
        "href": "/design-system/styles",
        "label": "Foundation styles",
        "current": currentSection == "Foundation styles"
      },
      {
        "href": "/design-system/components",
        "label": "Components",
        "current": currentSection == "Components"
      },
      {
        "href": "/design-system/patterns",
        "label": "Patterns",
        "current": currentSection == "Patterns"
      }
    ]
  }) }}
{% endmacro %}

