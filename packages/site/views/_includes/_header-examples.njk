{% macro siteHeader(currentSection='') %}
  {{ header({
    "theme": "light",
    "brand": {
      "href": "/",
      "ariaLabel": "Our Future Health design system home"
    },
    "navigation": [
      {
        "href": "/get-started",
        "label": "Get started",
        "current": currentSection == "Get started"
      },
      {
        "href": "/design-system/styles",
        "label": "Foundation styles",
        "current": currentSection == "Foundation styles"
      },
      {
        "href": "/design-system/components",
        "label": "Components",
        "current": currentSection == "Components"
      },
      {
        "href": "/design-system/patterns",
        "label": "Patterns",
        "current": currentSection == "Patterns"
      }
    ]
  }) }}
{% endmacro %}

{% macro showcaseHeader(theme='dark', idPrefix='header-showcase', accountState='sign-in') %}
  {% set resolvedAccount = {
    "type": "sign-in",
    "href": "#"
  } %}

  {% if accountState == 'account' %}
    {% set resolvedAccount = {
      "type": "account",
      "accountHref": "#",
      "signOutHref": "#"
    } %}
  {% endif %}

  {{ header({
    "idPrefix": idPrefix,
    "theme": theme,
    "brand": {
      "href": "#",
      "ariaLabel": "Our Future Health home",
      "nhsLogo": "england"
    },
    "utilityLinks": showcaseUtilityLinks,
    "search": {
      "action": "#",
      "label": {
        "text": "Search the site"
      },
      "input": {
        "id": idPrefix + "-search",
        "placeholder": "Search"
      }
    },
    "action": {
      "href": "#",
      "label": "Join now"
    },
    "account": resolvedAccount,
    "navigation": showcaseNavigation
  }) }}
{% endmacro %}

{% macro desktopDropdownOpenHeader(theme='dark', idPrefix='header-desktop-open') %}
  {{ showcaseHeader(theme, idPrefix) }}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var desktopTrigger = document.querySelector('[aria-controls="{{ idPrefix }}-desktop-group-1-panel"]');

      if (desktopTrigger) {
        desktopTrigger.click();
      }
    });
  </script>
{% endmacro %}

{% macro mobileMenuOpenHeader(theme='dark', idPrefix='header-mobile-open') %}
  <div style="max-width: 28rem;">
    {{ showcaseHeader(theme, idPrefix) }}
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var menuButton = document.querySelector('[aria-controls="{{ idPrefix }}-mobile-panel"]');
      var mobileTrigger = document.querySelector('[aria-controls="{{ idPrefix }}-mobile-group-1-panel"]');

      if (menuButton) {
        menuButton.click();
      }

      if (mobileTrigger) {
        mobileTrigger.click();
      }
    });
  </script>
{% endmacro %}
