{% macro showcaseHeader(theme='dark') %}
  {{ header({
    "idPrefix": "header-showcase-" + theme,
    "theme": theme,
    "brand": {
      "href": "#",
      "ariaLabel": "Our Future Health home",
      "nhsLogo": "england"
    },
    "utilityLinks": [
      {
        "href": "#",
        "label": "View docs",
        "openInNewWindow": true
      },
      {
        "href": "#",
        "label": "View GitHub",
        "openInNewWindow": true
      },
      {
        "href": "#",
        "label": "View Confluence",
        "openInNewWindow": true
      },
      {
        "href": "#",
        "label": "View Storybook",
        "openInNewWindow": true
      }
    ],
    "search": {
      "action": "#",
      "label": {
        "text": "Search the site"
      },
      "input": {
        "id": "header-showcase-search-" + theme,
        "placeholder": "Search"
      }
    },
    "action": {
      "href": "#",
      "label": "Join now"
    },
    "account": {
      "type": "sign-in",
      "href": "#"
    },
    "navigation": [
      {
        "href": "#",
        "label": "About"
      },
      {
        "label": "Research",
        "items": [
          {
            "href": "#",
            "label": "Participant portal"
          },
          {
            "href": "#",
            "label": "Data access",
            "current": true
          },
          {
            "href": "#",
            "label": "Publications"
          }
        ]
      },
      {
        "href": "#",
        "label": "Events"
      },
      {
        "href": "#",
        "label": "Support"
      },
      {
        "href": "#",
        "label": "Contact"
      }
    ]
  }) }}
{% endmacro %}

