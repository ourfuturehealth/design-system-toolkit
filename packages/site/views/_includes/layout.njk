{% from 'link-skip/macro.njk' import linkSkip %}
{% from 'link-action/macro.njk' import linkAction %}
{% from 'breadcrumb/macro.njk' import breadcrumb %}
{% from 'contents-list/macro.njk' import contentsList %}
{% from 'details/macro.njk' import details %}
{% from 'hero/macro.njk' import hero %}
{% from 'do-dont-list/macro.njk' import list %}
{% from 'image/macro.njk' import image %}
{% from 'pagination/macro.njk' import pagination %}
{% from 'tables/macro.njk' import table %}
{% from 'warning-callout/macro.njk' import warningCallout %}
{% from 'back-link/macro.njk' import backLink %}
{% from 'button/macro.njk' import button %}
{% from 'checkboxes/macro.njk' import checkboxes %}
{% from 'date-input/macro.njk' import dateInput %}
{% from 'error-message/macro.njk' import errorMessage %}
{% from 'error-summary/macro.njk' import errorSummary %}
{% from 'fieldset/macro.njk' import fieldset %}
{% from 'hint/macro.njk' import hint %}
{% from 'input/macro.njk' import input %}
{% from 'label/macro.njk' import label %}
{% from 'radios/macro.njk' import radios %}
{% from 'select/macro.njk' import select %}
{% from 'summary-list/macro.njk' import summaryList %}
{% from 'textarea/macro.njk' import textarea %}
{%- from 'design-example.njk' import designExample with context %}
{% set hideContact = "true" %}

<!DOCTYPE html>
  <html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% if pageDescription %}{{pageDescription}}{% else %}Our Future Health design system docs{% endif %}" />
    {%- block extraMeta %}{% endblock %}

    <title>{% if pageTitle %}{{ pageTitle }} - Our Future Health design system{% else %}Our Future Health design system{% endif %}</title>

    <link rel="stylesheet" href="/css/main.css">

    <script src="/js/main.min.js" defer></script>

    <link rel="shortcut icon" href="/ofh-design-system-toolkit/assets/favicons/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="/ofh-design-system-toolkit/assets/favicons/apple-touch-icon-180x180.png">
    <link rel="mask-icon" href="/ofh-design-system-toolkit/assets/favicons/favicon.svg" color="#FFC62C">
    <link rel="icon" sizes="192x192" href="/ofh-design-system-toolkit/assets/favicons/favicon-192x192.png">
    <meta name="msapplication-TileImage" content="/ofh-design-system-toolkit/assets/favicons/favicon-270x270.png">
    <meta name="msapplication-TileColor" content="#FFC62C">

    <meta property="og:url" content="https://ourfuturehealth.github.io/design-system-toolkit/"/>
    <meta property="og:title" content="{% if pageTitle %}{{ pageTitle }} - Our Future Health design system{% else %}Our Future Health design system{% endif %}"/>
    <meta property="og:description" content="{% if pageDescription %}{{pageDescription}}{% else %}Things you need to start building accessible user interfaces for Our Future Health websites and services.{% endif %}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:locale" content="en_GB"/>

    <meta property="og:image" content="/ofh-design-system-toolkit/assets/logos/ofh-marque_lge.png" />
    <meta property="og:image:width" content="1080" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:image:alt" content="Our Future Health" />

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@ukfuturehealth">
    <meta name="twitter:creator" content="@ukfuturehealth">
  </head>

  <body class="body-ds">
    <script>document.body.className = ((document.body.className) ? document.body.className + ' js-enabled' : 'js-enabled');</script>

    {{ linkSkip({
      href: '#maincontent',
      text: 'Skip to main content'
    }) }}

    {% include "_header.njk" %}

    {% block breadcrumb %}
      {{ breadcrumb({
        href: "/",
        text: "Home",
        classes: "app-breadcrumb"
      }) }}
    {% endblock %}

    {% block outerBody %}{% endblock %}

    {%- if beta %}
    {% include "_beta-banner.njk" %}
    {% endif %}

    {%- if unpublished %}
    {% include "_is-unpublished-banner.njk" %}
    {% endif %}

    {% if pageLayout != "Homepage" %}
    <div class="ofh-width-container app-width-container">
      <main class="ofh-main-wrapper app-main-wrapper" id="maincontent" role="main">
        {% block body %}{% endblock %}
      </main>
    </div>

    {% endif %}

    {% include "_footer.njk" %}

    {% block pageScripts %}{% endblock %}
  </body>

</html>
