{
  "name": "@ourfuturehealth/toolkit",
  "version": "4.0.0",
  "description": "Our Future Health design system toolkit contains the code you need to start building user interfaces for Our Future Health websites and services.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ourfuturehealth/design-system-toolkit.git",
    "directory": "packages/toolkit"
  },
  "license": "MIT",
  "files": [
    "dist",
    "components",
    "core",
    "common",
    "assets",
    "ofh.js",
    "ofh.scss",
    "polyfills.js"
  ],
  "main": "dist/ofh-design-system-toolkit.js",
  "style": "dist/ofh-design-system-toolkit.css",
  "scripts": {
    "prepare": "gulp bundle",
    "build": "gulp build",
    "dev": "gulp watch",
    "watch": "gulp watch",
    "clean": "gulp clean",
    "bundle": "gulp bundle",
    "zip": "gulp zip",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "lint:js": "eslint components/**/*.js *.js --ignore-pattern '*.config.js'",
    "lint:js:fix": "eslint --fix components/**/*.js *.js --ignore-pattern '*.config.js'",
    "lint:css": "stylelint -f verbose '**/*.scss'",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.21.3",
    "@babel/preset-env": "^7.20.2",
    "babel-loader": "^9.1.2",
    "eslint": "^8.36.0",
    "eslint-config-nhsuk": "^1.0.0",
    "glob": "^8.1.0",
    "gulp": "^5.0.0",
    "gulp-clean": "^0.4.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-rename": "^2.0.0",
    "gulp-sass": "^5.1.0",
    "gulp-uglify": "^3.0.2",
    "gulp-zip": "^5.1.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "sass": "^1.60.0",
    "stylelint": "^14.16.1",
    "stylelint-config-standard-scss": "^4.0.0",
    "stylelint-order": "^6.0.4",
    "stylelint-scss": "^4.1.0",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.0.1",
    "webpack-stream": "^7.0.0"
  },
  "dependencies": {
    "accessible-autocomplete": "^3.0.1",
    "i18n-js": "^4.5.1"
  }
