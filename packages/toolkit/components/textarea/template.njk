{% from "../error-message/macro.njk" import errorMessage -%}
{% from "../hint/macro.njk" import hint %}
{% from "../label/macro.njk" import label %}

{#- a record of other elements that we need to associate with the input using
   aria-describedby – for example hints or error messages -#}
{% set describedBy = "" %}
{% set externalDescribedBy = params.describedBy if params.describedBy else "" %}
{% set labelClasses = params.label.classes %}
{% if not labelClasses %}
  {% if params.label.isPageHeading %}
    {% set labelClasses = "ofh-label--l ofh-input__label" %}
  {% else %}
    {% set labelClasses = "ofh-label--s ofh-input__label" %}
  {% endif %}
{% else %}
  {% set labelClasses = labelClasses + " ofh-input__label" %}
{% endif %}
{% set hintClasses = "ofh-input__hint" %}
{% if params.hint and params.hint.classes %}
  {% set hintClasses = hintClasses + " " + params.hint.classes %}
{% endif %}
{% set errorClasses = "ofh-input__error-message" %}
{% if params.errorMessage and params.errorMessage.classes %}
  {% set errorClasses = errorClasses + " " + params.errorMessage.classes %}
{% endif %}
<div class="ofh-form-group {%- if params.errorMessage %} ofh-form-group--error{% endif %} {%- if params.formGroup.classes %} {{ params.formGroup.classes }}{% endif %}">
  <div class="ofh-input__header">
    {{ label({
      html: params.label.html,
      text: params.label.text,
      classes: labelClasses,
      isPageHeading: params.label.isPageHeading,
      attributes: params.label.attributes,
      for: params.id
    }) | indent(4) | trim }}
  {%- if params.hint %}
    {%- set hintId = params.id + '-hint' %}
    {%- set describedBy = describedBy + ' ' + hintId if describedBy else hintId %}
    {{ hint({
      id: hintId,
      classes: hintClasses,
      attributes: params.hint.attributes,
      html: params.hint.html,
      text: params.hint.text
    }) | indent(4) | trim }}
  {%- endif %}
  {%- if params.errorMessage %}
    {%- set errorId = params.id + '-error' %}
    {%- set describedBy = describedBy + ' ' + errorId if describedBy else errorId %}
    {{ errorMessage({
      id: errorId,
      classes: errorClasses,
      html: params.errorMessage.html,
      text: params.errorMessage.text
    }) | indent(4) | trim }}
  {%- endif %}
  </div>
{% if externalDescribedBy %}
  {%- set describedBy = describedBy + ' ' + externalDescribedBy if describedBy else externalDescribedBy %}
{% endif %}
  <textarea class="ofh-textarea
  {%- if params.errorMessage %} ofh-textarea--error{% endif %}
  {%- if params.classes %} {{ params.classes }}{% endif %}" id="{{ params.id }}" name="{{ params.name }}" rows="{{ params.rows | default('5') }}"
  {%- if describedBy %} aria-describedby="{{ describedBy }}"{% endif %}
  {%- if params.errorMessage %} aria-invalid="true"{% endif %}
  {%- if params.autocomplete %} autocomplete="{{ params.autocomplete}}"{% endif %}
  {%- for attribute, value in params.attributes %} {{attribute}}="{{value}}"{% endfor %}>{% if params.value is defined and params.value != null %}{{ params.value }}{% endif %}</textarea>
</div>
