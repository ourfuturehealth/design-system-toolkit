{# Define type of element to use, if not explicitly set #}

{% if params.element %}
  {% set element = params.element | lower %}
{% else %}
  {% if params.href %}
    {% set element = 'a' %}
  {% else %}
    {% set element = 'button' %}
  {% endif %}
{% endif %}

{% set isAnchor = element == 'a' %}
{% set anchorTarget = params.attributes.target if params.attributes and params.attributes.target else '' %}
{% set anchorRel = params.attributes.rel if params.attributes and params.attributes.rel else '' %}
{% set anchorOpensInNewWindow = isAnchor and anchorTarget == '_blank' %}
{% set anchorRelTokens = ' ' ~ anchorRel ~ ' ' %}
{% set anchorRelHasNoopener = ' noopener ' in anchorRelTokens %}
{% set anchorRelHasNoreferrer = ' noreferrer ' in anchorRelTokens %}
{% set safeAnchorRel %}{{ anchorRel }}{% if not anchorRelHasNoopener %}{% if anchorRel %} {% endif %}noopener{% endif %}{% if not anchorRelHasNoreferrer %}{% if anchorRel or not anchorRelHasNoopener %} {% endif %}noreferrer{% endif %}{% endset %}

{# Define common attributes that we can use across all element types #}
{% set commonAttributes %} class="ofh-button
  {%- if params.classes %}
    {{ params.classes }}
  {% else %}
    ofh-button--contained
  {% endif %}
  {%- if params.disabled %} ofh-button--disabled{% endif %}"
  {%- for attribute, value in params.attributes %}{% if not (anchorOpensInNewWindow and attribute == 'rel') %} {{attribute}}="{{value}}"{% endif %}{% endfor %}
  {%- if anchorOpensInNewWindow %} rel="{{ safeAnchorRel | trim }}"{% endif %}
{%- endset -%}

{# Define common attributes we can use for both button and input types #}
{%- set buttonAttributes %}{% if params.name %} name="{{ params.name }}"{% endif %} type="{{ params.type if params.type else 'submit' }}"
   {%- if params.disabled %} disabled="disabled" aria-disabled="true"{% endif %}
 {%- endset -%}

{% if element == 'a' %}
<a{{ commonAttributes | safe }} href="{{ params.href if params.href else '#' }}" draggable="false"{%- if params.disabled %} aria-disabled="true"{% endif %}>
  {{ params.html | safe if params.html else params.text }}
</a>

{% elseif element == 'button' %}
<button{{ commonAttributes | safe }}{% if params.value %} value="{{ params.value }}"{% endif %}{{ buttonAttributes | safe }}>
  {{ params.html | safe if params.html else params.text }}
</button>

{% elseif element == 'input' %}
<input{{ commonAttributes | safe }} value="{{ params.text }}"{{ buttonAttributes | safe }}>

{% endif %}
