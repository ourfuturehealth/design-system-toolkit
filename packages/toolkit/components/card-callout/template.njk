{% set headingLevel = params.headingLevel if params.headingLevel else 3 %}
{% set variant = params.variant if params.variant else 'info' %}

<div class="ofh-card-callout ofh-card-callout--{{ variant }}
{%- if params.rootAliasClass %} {{ params.rootAliasClass }}{% endif %}
{%- if params.classes %} {{ params.classes }}{% endif %}"
{%- for attribute, value in params.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
  <h{{ headingLevel }} class="ofh-card-callout__label
  {%- if params.labelAliasClass %} {{ params.labelAliasClass }}{% endif %}">
    {%- if params.headingHtml %}
      {{ params.headingHtml | safe }}
    {%- elif params.visuallyHiddenPrefix %}
      <span role="text">
        <span class="ofh-u-visually-hidden">{{ params.visuallyHiddenPrefix }} </span>
        {{ params.heading | safe }}
      </span>
    {%- else %}
      {{ params.heading | safe }}
    {%- endif %}
  </h{{ headingLevel }}>
  <div class="ofh-card-callout__content
  {%- if params.contentAliasClass %} {{ params.contentAliasClass }}{% endif %}">
    <div class="ofh-card-callout__spacer" aria-hidden="true"></div>
    <div class="ofh-card-callout__body">
      {%- if params.html %}
        {{ params.html | safe }}
      {%- elif params.HTML %}
        {{ params.HTML | safe }}
      {%- elif params.text %}
        <p>{{ params.text }}</p>
      {%- endif %}
    </div>
  </div>
</div>
