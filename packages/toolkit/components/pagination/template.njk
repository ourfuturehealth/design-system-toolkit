{% from '../icon/macro.njk' import icon %}

<nav class="ofh-pagination
{%- if params.classes %} {{ params.classes }}{% endif %}" role="navigation" aria-label="Pagination"
{%- for attribute, value in params.attributes %} {{attribute}}="{{value}}"{% endfor %}>
  <ul class="ofh-list ofh-pagination__list">
  {%- if params.previousUrl and params.previousPage %}
    <li class="ofh-pagination-item--previous">
      <a class="ofh-pagination__link ofh-pagination__link--prev" href="{{ params.previousUrl }}">
        <span class="ofh-pagination__title">Previous</span>
        <span class="ofh-u-visually-hidden">:</span>
        <span class="ofh-pagination__page">{{ params.previousPage }}</span>
        {{ icon({ "name": "ArrowLeft", "size": 32, "classes": "ofh-pagination__icon" }) }}
      </a>
    </li>
  {%- endif %}
  {%- if params.nextUrl and params.nextPage %}
    <li class="ofh-pagination-item--next">
      <a class="ofh-pagination__link ofh-pagination__link--next" href="{{ params.nextUrl }}">
        <span class="ofh-pagination__title">Next</span>
        <span class="ofh-u-visually-hidden">:</span>
        <span class="ofh-pagination__page">{{ params.nextPage }}</span>
        {{ icon({ "name": "ArrowRight", "size": 32, "classes": "ofh-pagination__icon" }) }}
      </a>
    </li>
  {%- endif %}
  </ul>
</nav>
