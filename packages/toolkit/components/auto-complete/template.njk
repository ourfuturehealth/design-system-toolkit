{% from "../input/macro.njk" import input %}
{% set optionsKey = params.id + '_options' %}

<div class="ofh-js-autocomplete-element">
  {{ input({
    "label": {
      "text": params.label
    },
    "describedBy": params.describedBy,
    "id": params.id,
    "name": params.name,
    "value": params.value,
    "hint": params.hint,
    "errorMessage": params.errorMessage,
    "formGroup": params.formGroup,
    "classes": params.classes,
    "attributes": params.attributes
  }) }}
  <div
    class="ofh-js-autocomplete-element-suggestions"
    data-default-value="{{params.value}}"
    data-field-name="{{params.name}}"
    {% if params.noResultsText %}data-no-results-text="{{params.noResultsText}}"{% endif %}
  ></div>
  <script>
    window[{{ optionsKey | dump | safe }}] = {{ params.options | dump | safe }};
  </script>
</div>
