{% from '../icon/macro.njk' import icon %}

{% set headingLevel = params.headingLevel if params.headingLevel else 3 %}
<div class="ofh-do-dont-list
{%- if params.classes %} {{ params.classes }}{% endif %}"
{%- for attribute, value in params.attributes %} {{attribute}}="{{value}}"{% endfor %}>
  <h{{ headingLevel }} class="ofh-do-dont-list__label">{{ params.title }}</h{{ headingLevel }}>
  <ul class="ofh-list {% if params.type == 'tick' %}ofh-list--tick{% else %}ofh-list--cross{% endif %}">
    {%- for data in params.items %}
    <li>
    {%- if params.type == 'cross' %}
      {{ icon({ "name": "Close", "size": 32, "classes": "ofh-do-dont-list__icon ofh-do-dont-list__icon--cross" }) }}
    {%- else %}
      {{ icon({ "name": "Done", "size": 32, "classes": "ofh-do-dont-list__icon ofh-do-dont-list__icon--tick" }) }}
    {%- endif %}
      {% if params.type == 'cross' %}{% if not params.hidePrefix %}do not {% endif %}{% endif %}{{ data.item | safe}}
    </li>
    {%- endfor %}
  </ul>
</div>
