{% from '../icon/macro.njk' import icon %}

<div class="ofh-back-link{%- if params.classes %} {{ params.classes }}{% endif %}">
  <a class="ofh-back-link__link" href="
  {%- if params.href %}{{ params.href }}{% else %}#{% endif %}"
  {%- for attribute, value in params.attributes %} {{attribute}}="{{value}}"{% endfor %}>
  {{ icon({ "name": "chevron-left", "size": 24, "classes": "ofh-back-link__icon" }) }}
  {{ (params.html | safe if params.html else (params.text if params.text else 'Back')) }}</a>
</div>
