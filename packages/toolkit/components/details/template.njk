{% from '../icon/macro.njk' import icon %}

<details class="ofh-details
{%- if params.classes %} {{ params.classes }}{% endif %}"
{%- for attribute, value in params.attributes %} {{attribute}}="{{value}}"{% endfor %}>
  <summary class="ofh-details__summary">
    <span class="ofh-details__summary-text">
      {%- if params.classes and 'ofh-expander' in params.classes -%}
        {{ icon({ "name": "plus-circle-solid", "size": 32, "classes": "ofh-details__expander-icon ofh-details__expander-icon--expand" }) }}
        {{ icon({ "name": "minus-circle-solid", "size": 32, "classes": "ofh-details__expander-icon ofh-details__expander-icon--collapse" }) }}
      {%- endif -%}
      {{ params.text }}
    </span>
  </summary>
  <div class="ofh-details__text">
    {{- params.HTML | safe }}
  </div>
</details>
