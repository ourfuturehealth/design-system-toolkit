{% from '../icon/macro.njk' import icon %}

{% macro card(params, withIcon) %}
  {%- include "./template.njk" -%}
{% endmacro %}

{% macro cardWithIcon(params) %}
  {% call card(params, true) -%}
    {{ icon({ "name": "Check", "size": 32, "classes": "ofh-card__icon" }) }}
  {%- endcall %}
{% endmacro %}
