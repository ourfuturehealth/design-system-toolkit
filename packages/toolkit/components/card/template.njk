{% from '../icon/macro.njk' import icon %}
{% from '../tag/macro.njk' import tag %}
{% set headingLevel = params.headingLevel if params.headingLevel else 2 %}
{% set variant = params.variant if params.variant else ('clickable' if params.clickable else 'basic') %}
{% set isClickable = variant == 'clickable' %}
{% set hasLegacyCare = params.type %}
{% set hasLegacyFeature = params.feature %}
{% set hasTrailingContent = (params.icon or withIcon or caller) and not hasLegacyCare %}
{% set dismissButton = params.dismissButton if params.dismissButton else false %}
{% set contentHtml = params.descriptionHtml if params.descriptionHtml else params.HTML %}

<div class="ofh-card
{%- if isClickable %} ofh-card--clickable{% endif %}
{%- if hasLegacyCare %} ofh-card--care ofh-card--care--{{ params.type }}{% endif %}
{%- if hasLegacyFeature %} ofh-card--feature{% endif %}
{%- if hasTrailingContent %} ofh-card__with-icon{% endif %}
{%- if params.classes %} {{ params.classes }}{% endif %}"
{%- for attribute, value in params.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
  {%- if params.imgURL %}
    <img class="ofh-card__img" src="{{ params.imgURL }}" alt="{{ params.imgALT }}">
  {%- endif %}

  {%- if hasLegacyCare %}
    <div class="ofh-card--care__heading-container">
      <div>
        {%- if params.headingHtml %}
          {{ params.headingHtml | safe }}
        {%- elif params.heading %}
          <h{{ headingLevel }}
            class="ofh-card--care__heading{% if params.headingClasses %} {{ params.headingClasses }}{% endif %}">
            {%- if params.href %}
              <a class="ofh-card__link" href="{{ params.href }}">{{ params.heading | safe }}</a>
            {%- else %}
              <span role="text"><span class="ofh-u-visually-hidden">
              {%- if params.type == 'non-urgent' %}Non-urgent advice:
              {%- elseif params.type == 'urgent' %}Urgent advice:
              {%- elseif params.type == 'emergency' %}Immediate action required:
              {%- else %}Non-urgent advice:{% endif %} </span>{{ params.heading }}</span>
            {%- endif %}
          </h{{ headingLevel }}>
        {%- endif %}
        <span class="ofh-card--care__arrow" aria-hidden="true"></span>
        {%- if contentHtml %}
          {{ contentHtml | safe }}
        {%- elif params.description %}
          <p class="ofh-card__description">{{ params.description | safe }}</p>
        {%- endif %}
        {%- if caller %}
          <div class="ofh-u-padding-left-6">
            {{ caller() }}
          </div>
        {%- endif %}
      </div>
    </div>
  {%- else %}
    <div class="ofh-card__content
                {%- if hasLegacyFeature %} ofh-card__content--feature{% endif %}
                {%- if hasTrailingContent %} ofh-card__content--with-aside{% endif %}
                {%- if dismissButton and not params.imgURL %} ofh-card__content--dismissible{% endif %}">
      <div class="ofh-card__main">
        {%- if params.headingHtml %}
          {{ params.headingHtml | safe }}
        {%- elif params.heading %}
          <h{{ headingLevel }}
            class="ofh-card__heading{% if hasLegacyFeature %} ofh-card__heading--feature{% endif %}{% if params.headingClasses %} {{ params.headingClasses }}{% endif %}">
            {%- if params.href and not hasLegacyFeature %}
              <a
                class="ofh-card__link{% if isClickable %} ofh-card__primary-link{% endif %}"
                href="{{ params.href }}"
                {% if isClickable %}data-ofh-card-primary-link="true"{% endif %}>
                {{ params.heading | safe }}
              </a>
            {%- else %}
              {{ params.heading }}
            {%- endif %}
          </h{{ headingLevel }}>
        {%- endif %}

        {%- if params.number %}
          <p class="ofh-card__number">{{ params.number | safe }}</p>
        {%- endif %}

        {%- if params.tag %}
          {{ tag(params.tag) }}
        {%- endif %}

        {%- if contentHtml %}
          {{ contentHtml | safe }}
        {%- elif params.description %}
          <p class="ofh-card__description">{{ params.description | safe }}</p>
        {%- endif %}

        {%- if params.metadataItems %}
          <div class="ofh-card__metadata-list">
            {%- for item in params.metadataItems %}
              <div class="ofh-card__metadata-item">
                <span class="ofh-card__metadata-icon-container" aria-hidden="true">
                  {{ icon({
                    "name": item.icon,
                    "size": item.size if item.size else 24,
                    "classes": "ofh-card__metadata-icon"
                  }) }}
                </span>
                <span class="ofh-card__metadata-text">{{ item.text | safe }}</span>
              </div>
            {%- endfor %}
          </div>
        {%- endif %}

        {%- if params.helperHtml %}
          <div class="ofh-card__helper">{{ params.helperHtml | safe }}</div>
        {%- elif params.helperText %}
          <p class="ofh-card__helper">{{ params.helperText | safe }}</p>
        {%- endif %}

        {%- if params.actionLink %}
          <p class="ofh-card__action">
            <a
              class="ofh-card__action-link{% if isClickable and not params.href %} ofh-card__primary-link{% endif %}"
              href="{{ params.actionLink.href }}"
              {%- if isClickable and not params.href %} data-ofh-card-primary-link="true"{% endif %}
              {%- for attribute, value in params.actionLink.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
              {{ params.actionLink.text | safe }}
            </a>
          </p>
        {%- endif %}
      </div>

      {%- if hasTrailingContent %}
        <div class="ofh-card__aside">
          {%- if params.icon %}
            {{ icon({
              "name": params.icon.name,
              "size": params.icon.size if params.icon.size else 32,
              "title": params.icon.title,
              "attributes": params.icon.attributes,
              "classes": "ofh-card__icon" ~ (" " ~ params.icon.classes if params.icon.classes else "")
            }) }}
          {%- endif %}
          {%- if caller %}
            {{ caller() }}
          {%- endif %}
        </div>
      {%- endif %}
    </div>
  {%- endif %}

  {%- if dismissButton %}
    <button class="ofh-card__dismiss" type="button"
    {%- for attribute, value in dismissButton.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
      <span class="ofh-u-visually-hidden">
        {{ dismissButton.label if dismissButton.label else 'Dismiss card' }}
      </span>
      {{ icon({ "name": "Close", "size": 32, "classes": "ofh-card__dismiss-icon" }) }}
    </button>
  {%- endif %}
</div>
