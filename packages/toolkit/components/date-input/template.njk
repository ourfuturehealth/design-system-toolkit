{% from "../error-message/macro.njk" import errorMessage -%}
{% from "../fieldset/macro.njk" import fieldset %}
{% from "../hint/macro.njk" import hint %}

{#- a record of other elements that we need to associate with the input using
   aria-describedby – for example hints or error messages -#}
{% set describedBy = "" %}
{% set externalDescribedBy = params.describedBy if params.describedBy else "" %}

{% if params.items %}
  {% set dateInputItems = params.items %}
{% else %}
  {% set dateInputItems = [
    {
      name: "day",
      classes: "ofh-input--width-2"
    },
    {
      name: "month",
      classes: "ofh-input--width-2"
    },
    {
      name: "year",
      classes: "ofh-input--width-4"
    }
  ] %}
{% endif %}
{% if params.fieldset and params.fieldset.legend %}
  {% set legendClasses = params.fieldset.legend.classes %}
  {% if not legendClasses %}
    {% if params.fieldset.legend.isPageHeading %}
      {% set legendClasses = "ofh-fieldset__legend--l ofh-input__legend" %}
    {% else %}
      {% set legendClasses = "ofh-fieldset__legend--s ofh-input__legend" %}
    {% endif %}
  {% else %}
    {% set legendClasses = legendClasses + " ofh-input__legend" %}
  {% endif %}
  {% if params.hint or params.errorMessage %}
    {% set legendClasses = legendClasses + " ofh-input__legend--with-supporting-text" %}
  {% endif %}
{% endif %}

{#- Capture the HTML so we can optionally nest it in a fieldset -#}
{%- set innerHtml -%}
{% if params.hint %}
  {% set hintId = params.id + "-hint" %}
  {% set describedBy = describedBy + " " + hintId if describedBy else hintId %}

  {% set hintClasses = "ofh-input__hint" %}
  {% if params.hint.classes %}
    {% set hintClasses = hintClasses + " " + params.hint.classes %}
  {% endif %}
{% endif %}
{% if params.errorMessage %}
  {% set errorId = params.id + "-error" %}
  {% set describedBy = describedBy + " " + errorId if describedBy else errorId %}
  {% set errorClasses = "ofh-input__error-message" %}
  {% if params.errorMessage.classes %}
    {% set errorClasses = errorClasses + " " + params.errorMessage.classes %}
  {% endif %}
{% endif %}
{% if externalDescribedBy %}
  {% set describedBy = describedBy + " " + externalDescribedBy if describedBy else externalDescribedBy %}
{% endif %}
{% if params.hint or params.errorMessage %}
  <div class="ofh-input__header">
  {% if params.hint %}
    {{ hint({
      id: hintId,
      classes: hintClasses,
      attributes: params.hint.attributes,
      html: params.hint.html,
      text: params.hint.text
    }) | indent(4) | trim }}
  {% endif %}
  {% if params.errorMessage %}
    {{ errorMessage({
      id: errorId,
      classes: errorClasses,
      html: params.errorMessage.html,
      text: params.errorMessage.text
    }) | indent(4) | trim }}
  {% endif %}
  </div>
{% endif %}
  <div class="ofh-date-input
    {%- if params.classes %} {{ params.classes }}{% endif %}"
    {%- for attribute, value in params.attributes %} {{attribute}}="{{value}}"{% endfor %}
    {%- if params.id %} id="{{ params.id }}"{% endif %}>
  {%- for item in dateInputItems %}
    {% set inputId = item.id if item.id else ((params.id + "-" + item.name) if params.id else item.name) %}
    {% set inputClasses = "ofh-input ofh-date-input__input" %}
    {% if item.classes %}
      {% set inputClasses = inputClasses + " " + item.classes %}
    {% endif %}
    <div class="ofh-date-input__item ofh-date-input__item--{{ item.name }}">
      <label class="ofh-date-input__label" for="{{ inputId }}">
        {{ item.label if item.label else item.name | capitalize }}
      </label>
      <input class="{{ inputClasses }}"
        id="{{ inputId }}"
        name="{{ (params.namePrefix + "-" + item.name) if params.namePrefix else item.name }}"
        type="text"
        inputmode="{{ item.inputmode if item.inputmode else 'numeric' }}"
        {%- if item.value is defined and item.value != null %} value="{{ item.value }}"{% endif %}
        {%- if item.autocomplete %} autocomplete="{{ item.autocomplete }}"{% endif %}
        pattern="{{ item.pattern if item.pattern else '[0-9]*' }}"
        {%- for attribute, value in item.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>
    </div>
  {%- endfor -%}
  </div>
{%- endset -%}

<div class="ofh-form-group {%- if params.errorMessage %} ofh-form-group--error{% endif %}  {%- if params.formGroup.classes %} {{ params.formGroup.classes }}{% endif %}">
{% if params.fieldset %}
{#- We override the fieldset's role to 'group' because otherwise JAWS does not
    announce the description for a fieldset comprised of text inputs, but
    adding the role to the fieldset always makes the output overly verbose for
    radio buttons or checkboxes. -#}
  {% call fieldset({
    describedBy: describedBy,
    classes: params.fieldset.classes,
    attributes: {
      role: "group"
    },
    legend: {
      html: params.fieldset.legend.html,
      text: params.fieldset.legend.text,
      classes: legendClasses,
      isPageHeading: params.fieldset.legend.isPageHeading
    }
  }) %}
  {{- innerHtml | trim | safe -}}
  {% endcall %}
{% else %}
  {{- innerHtml | trim | safe -}}
{% endif %}
</div>
