{
  "name": "ofh-design-system-toolkit-monorepo",
  "private": true,
  "description": "Our Future Health design system toolkit monorepo. Individual packages have independent versioning - see packages/toolkit and packages/react-components for their versions.",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "prepare": "turbo run bundle",
    "dev": "turbo run watch --parallel",
    "dev:toolkit": "turbo run watch --filter=toolkit",
    "dev:site": "turbo run watch --filter=site",
    "dev:react-components": "turbo run watch --filter=react-components",
    "dev:consumer": "turbo run watch --filter=example-react-consumer-app",
    "storybook": "pnpm --filter=react-components run storybook",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:toolkit": "turbo run lint --filter=toolkit",
    "lint:site": "turbo run lint --filter=site",
    "lint:react-components": "turbo run lint --filter=react-components",
    "lint:consumer": "turbo run lint --filter=example-react-consumer-app",
    "test": "turbo run test",
    "test:toolkit": "turbo run test --filter=toolkit",
    "test:react-components": "turbo run test --filter=react-components",
    "test:watch": "pnpm --filter=react-components run test:watch"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "eslint": "^8.36.0",
    "eslint-config-nhsuk": "^1.0.0",
    "htmlhint": "^1.1.4",
    "husky": "^4.3.8",
    "stylelint": "^14.16.1",
    "stylelint-config-standard-scss": "^4.0.0",
    "stylelint-order": "^6.0.4",
    "stylelint-scss": "^4.1.0",
    "turbo": "^2.8.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "husky": {
    "hooks": {
      "pre-push": "pnpm run lint && pnpm test"
    }
  },
  "files": [
    "dist",
    "packages"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ourfuturehealth/design-system-toolkit.git"
  },
  "homepage": "https://ourfuturehealth.github.io/design-system-toolkit/",
  "license": "MIT"
}
