{
  "name": "ofh-design-system-toolkit-monorepo",
  "private": true,
  "description": "Our Future Health design system toolkit monorepo. Individual packages have independent versioning - see packages/toolkit and packages/react-components for their versions.",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "editorconfig@1.0.4>minimatch": "9.0.6",
      "minimatch@3.1.2": "3.1.3",
      "minimatch@5.1.6": "5.1.7",
      "minimatch@8.0.4": "8.0.5",
      "minimatch@9.0.1": "9.0.6",
      "minimatch@9.0.5": "9.0.6",
      "minimatch@10.1.2": "10.2.2",
      "markdown-it@13.0.2": "14.1.1",
      "ajv@8.12.0": "8.18.0",
      "ajv@8.13.0": "8.18.0",
      "ajv@8.17.1": "8.18.0"
    }
  },
  "scripts": {
    "prepare": "husky && turbo run bundle",
    "dev": "concurrently \"pnpm:dev:*\" \"pnpm storybook\"",
    "dev:toolkit": "pnpm --filter=@ourfuturehealth/toolkit run watch",
    "dev:site": "pnpm --filter=site run watch",
    "dev:react-components": "pnpm --filter=@ourfuturehealth/react-components run watch",
    "dev:react-consumer": "concurrently -n lib,app -c cyan,green \"pnpm --filter=@ourfuturehealth/react-components watch:lib\" \"pnpm --filter=@ourfuturehealth/example-react-consumer-app watch\"",
    "storybook": "pnpm --filter=@ourfuturehealth/react-components run storybook",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:toolkit": "turbo run lint --filter=@ourfuturehealth/toolkit",
    "lint:site": "turbo run lint --filter=site",
    "lint:react-components": "turbo run lint --filter=@ourfuturehealth/react-components",
    "lint:react-consumer": "turbo run lint --filter=@ourfuturehealth/example-react-consumer-app",
    "test": "turbo run test",
    "test:toolkit": "turbo run test --filter=@ourfuturehealth/toolkit",
    "test:react-components": "turbo run test --filter=@ourfuturehealth/react-components"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.4"
  },
  "files": [
    "dist",
    "packages"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ourfuturehealth/design-system-toolkit.git"
  },
  "license": "MIT"
}
